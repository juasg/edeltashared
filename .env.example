# ===== PostgreSQL (Metadata DB) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edeltashared
POSTGRES_USER=edeltashared
POSTGRES_PASSWORD=changeme_postgres

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ===== HANA Sidecar =====
HANA_HOST=
HANA_PORT=30015
HANA_USER=
HANA_PASSWORD=
HANA_MAX_CONNECTIONS=3
HANA_QUERY_TIMEOUT_MS=10000

# ===== Snowflake =====
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ===== Aurora (PostgreSQL target) =====
AURORA_HOST=localhost
AURORA_PORT=5433
AURORA_DATABASE=edeltashared_target
AURORA_USER=aurora_user
AURORA_PASSWORD=aurora_pass

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=edeltashared

# ===== CDC Agent =====
SIMULATOR_MODE=true
CDC_POLL_INTERVAL_SECONDS=3
CDC_BATCH_SIZE=1000
CDC_PURGE_INTERVAL_SECONDS=3600
CDC_HANA_CPU_THRESHOLD=70

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=changeme_secret_key_min_32_chars_long
ENCRYPTION_KEY=changeme_encryption_key_32_bytes

# ===== Frontend =====
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
